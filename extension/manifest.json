{
  "manifest_version": 3,
  "name": "PlayCanvas Agent Bridge",
  "description": "Connects open PlayCanvas Editor and Launch tabs to the local pcbridge daemon.",
  "version": "0.2.3",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://playcanvas.com/*",
    "https://playcanvas.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PlayCanvas Agent Bridge"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://playcanvas.com/editor*",
        "https://playcanvas.com/editor*",
        "http://launch.playcanvas.com/*",
        "https://launch.playcanvas.com/*"
      ],
      "js": ["main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://playcanvas.com/editor*",
        "https://playcanvas.com/editor*",
        "http://launch.playcanvas.com/*",
        "https://launch.playcanvas.com/*"
      ],
      "js": ["isolated.js"],
      "world": "ISOLATED",
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:*"
  }
}
